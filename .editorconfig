# ==============================================================================
# MLOps & Data Engineering Enterprise EditorConfig
# by IRONKAGE (https://github.com/IRONKAGE)
# ==============================================================================

# Це кореневий файл (IDE не повинна шукати інші конфіги вище по дереву папок)
root = true

# ------------------------------------------------------------------------------
# БАЗОВІ ПРАВИЛА ДЛЯ ВСІХ ФАЙЛІВ
# ------------------------------------------------------------------------------
[*]
charset = utf-8
# Завжди додавати порожній рядок в кінці файлу (стандарт POSIX)
insert_final_newline = true
# Автоматично видаляти зайві пробіли в кінці рядків (щоб Git diff був чистим)
trim_trailing_whitespace = true
indent_style = space
indent_size = 4

# 🔥 КРИТИЧНО ДЛЯ DOCKER: Завжди використовувати Linux-переноси рядків (LF).
# Якщо Windows-розробник збереже файл з CRLF, контейнер або скрипт впаде.
end_of_line = lf

# ------------------------------------------------------------------------------
# СЕКРЕТИ ТА ENV-ФАЙЛИ (.env)
# ------------------------------------------------------------------------------
[{.env,*.env,.env.*}]
# LF критично важливий для Docker та bash-скриптів, які парсять .env файли.
# Забороняємо автоматичне вирівнювання, щоб не зламати ключі доступу.
end_of_line = lf
indent_style = space
indent_size = 2

# ------------------------------------------------------------------------------
# PYTHON (Django, Marimo & ML Models)
# ------------------------------------------------------------------------------
[*.py]
indent_style = space
indent_size = 4
# Максимальна довжина рядка (стандарт PEP8 - 88 або 119 для Django/ML)
max_line_length = 119

# ------------------------------------------------------------------------------
# SQL ТА БАЗИ ДАНИХ (DDL / DML скрипти)
# ------------------------------------------------------------------------------
[*.sql]
indent_style = space
indent_size = 4
# В SQL часто бувають довгі складні запити з віконними функціями
max_line_length = 150

# ------------------------------------------------------------------------------
# ІНФРАСТРУКТУРА ТА КОНФІГИ (Docker, YAML, JSON, TOML, INI)
# ------------------------------------------------------------------------------
[*.{yml,yaml,json,toml,ini,cfg,conf,ipynb}]
indent_style = space
indent_size = 2

[Dockerfile*]
indent_style = space
indent_size = 4

# ------------------------------------------------------------------------------
# ДАНІ ТА ДАТАСЕТИ (CSV, TSV)
# ------------------------------------------------------------------------------
[*.{csv,tsv}]
# КРИТИЧНО ДЛЯ ДАНИХ: Забороняємо видаляти "зайві" пробіли в кінці,
# оскільки вони можуть бути значущою частиною датасету.
trim_trailing_whitespace = false
# Забороняємо додавати порожній рядок в кінці, щоб не створити фантомний row
insert_final_newline = false

# ------------------------------------------------------------------------------
# СКРИПТИ BASH / ZSH (Linux/Mac пускачі)
# ------------------------------------------------------------------------------
[*.{sh,zsh,bash}]
indent_style = space
indent_size = 4
# Жорстко фіксуємо LF для Bash-скриптів, інакше вони не запустяться в Docker
end_of_line = lf

# ------------------------------------------------------------------------------
# СКРИПТИ WINDOWS (Cmd, PowerShell)
# ------------------------------------------------------------------------------
[*.{cmd,bat}]
# Для старих Windows-скриптів безпечніше використовувати рідний формат CRLF
end_of_line = crlf
indent_style = space
indent_size = 4

[*.ps1]
# Сучасний PowerShell чудово розуміє LF
end_of_line = lf
indent_style = space
indent_size = 4

# ------------------------------------------------------------------------------
# ДОКУМЕНТАЦІЯ (Markdown, TXT)
# ------------------------------------------------------------------------------
[*.{md,txt}]
indent_style = space
indent_size = 2
# КРИТИЧНО: У Markdown два пробіли в кінці рядка означають жорсткий перенос рядка (<br>).
# Якщо IDE автоматично видалить їх (trim_trailing_whitespace), форматування зламається!
trim_trailing_whitespace = false

# ------------------------------------------------------------------------------
# ФРОНТЕНД / ВЕБ (HTML, CSS, JS, TS)
# ------------------------------------------------------------------------------
[*.{html,css,js,ts,jsx,tsx}]
indent_style = space
indent_size = 2

# ------------------------------------------------------------------------------
# MAKEFILES (Оркестрація)
# ------------------------------------------------------------------------------
[Makefile]
# Makefiles вимагають ВИКЛЮЧНО таби. Пробіли їх зламають.
indent_style = tab
# Відключаємо перевірку довжини рядка для консольних команд
max_line_length = off

# ------------------------------------------------------------------------------
# TERRAFORM (IaC)
# ------------------------------------------------------------------------------
[*.{tf,tfvars,hcl}]
indent_style = space
indent_size = 2
